    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Save or update lead information. Call this with email and any fields the user just provided.",
        "operation": "executeQuery",
        "query": "INSERT INTO leads (\n  email, name, company, product_idea,\n  budget, timeline, market, kpi,\n  expectations, stage, urgency, sessionid, phone\n)\nVALUES (\n  '{{ $json.email }}',\n  NULLIF('{{ $json.name }}', 'undefined'),\n  NULLIF('{{ $json.company }}', 'undefined'),\n  NULLIF('{{ $json.product_idea }}', 'undefined'),\n  NULLIF('{{ $json.budget }}', 'undefined')::integer,\n  NULLIF('{{ $json.timeline }}', 'undefined'),\n  NULLIF('{{ $json.market }}', 'undefined'),\n  NULLIF('{{ $json.kpi }}', 'undefined'),\n  NULLIF('{{ $json.expectations }}', 'undefined'),\n  NULLIF('{{ $json.stage }}', 'undefined'),\n  NULLIF('{{ $json.urgency }}', 'undefined'),\n  NULLIF('{{ $json.sessionId }}', 'undefined'),\n  NULLIF('{{ $json.phone }}', 'undefined')\n)\nON CONFLICT (email)\nDO UPDATE SET\n  name = COALESCE(EXCLUDED.name, leads.name),\n  company = COALESCE(EXCLUDED.company, leads.company),\n  product_idea = COALESCE(EXCLUDED.product_idea, leads.product_idea),\n  budget = COALESCE(EXCLUDED.budget, leads.budget),\n  timeline = COALESCE(EXCLUDED.timeline, leads.timeline),\n  market = COALESCE(EXCLUDED.market, leads.market),\n  kpi = COALESCE(EXCLUDED.kpi, leads.kpi),\n  expectations = COALESCE(EXCLUDED.expectations, leads.expectations),\n  stage = COALESCE(EXCLUDED.stage, leads.stage),\n  urgency = COALESCE(EXCLUDED.urgency, leads.urgency),\n  phone = COALESCE(EXCLUDED.phone, leads.phone),\n  sessionid = COALESCE(NULLIF(EXCLUDED.sessionid, 'undefined'), leads.sessionid),\n  last_updated = CURRENT_TIMESTAMP;\n\nINSERT INTO session_active_user (sessionid, current_email)\nVALUES ('{{ $json.sessionId }}', '{{ $json.email }}')\nON CONFLICT (sessionid)\nDO UPDATE SET current_email = EXCLUDED.current_email, updated_at = NOW();",
        "options": {}
      },
